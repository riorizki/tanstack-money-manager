{
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "css.customData": [".vscode/tailwindcss.custom-data.json"],
  "scss.customData": [".vscode/tailwindcss.custom-data.json"],
  "less.customData": [".vscode/tailwindcss.custom-data.json"],
  "files.watcherExclude": {
    "**/routeTree.gen.ts": true
  },
  "search.exclude": {
    "**/routeTree.gen.ts": true,
    "**/.output/**": true
  },
  "files.readonlyInclude": {
    "**/routeTree.gen.ts": true
  }
}
